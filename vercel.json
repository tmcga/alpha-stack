{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "installCommand": null,
  "functions": {
    "app.py": {
      "runtime": "@vercel/python@6.40.0"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/app.py" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "cleanUrls": true
}
